# ── CSV data source ───────────────────────────────────────────────────────────
CSV_BASE_PATH=../sample-data
CSV_REFRESH_INTERVAL_SECONDS=900

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS_STR=http://localhost:5173,http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:5432/dbname
# Render managed DB example: postgresql+asyncpg://cement:pass@oregon-postgres.render.com/cement_db
DATABASE_URL=postgresql+asyncpg://cement:cement@localhost:5432/cement_db

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme-replace-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Auth cookies ──────────────────────────────────────────────────────────────
# Local dev (same-site localhost): leave the defaults below.
# Cross-site production (frontend and backend on different domains, e.g.
# Vercel frontend + Render backend): set COOKIE_SAMESITE=none and
# COOKIE_SECURE=true so the browser will send the auth cookie across sites.
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# ── Admin bootstrap (shell-less hosts like Render free tier) ───────────────────
# If set, an admin with these credentials is created/refreshed on every startup.
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me
